{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codemax.local/contracts/ipc.schema.json",
  "title": "Codemax IPC Contract",
  "type": "object",
  "properties": {
    "commands": {
      "type": "object",
      "properties": {
        "health": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/HealthResponse"
            }
          },
          "required": ["response"]
        },
        "select_repository_path": {
          "type": "object",
          "properties": {
            "response": {
              "anyOf": [
                {
                  "$ref": "#/$defs/RepositoryPathSelection"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": ["response"]
        },
        "validate_repository_path": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/RepositoryPathRequest"
            },
            "response": {
              "$ref": "#/$defs/RepositorySummary"
            }
          },
          "required": ["request", "response"]
        },
        "get_repository_current_branch": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/RepositoryPathRequest"
            },
            "response": {
              "$ref": "#/$defs/RepositoryBranchInfo"
            }
          },
          "required": ["request", "response"]
        },
        "get_repository_dirty_status": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/RepositoryPathRequest"
            },
            "response": {
              "$ref": "#/$defs/RepositoryDirtyStatus"
            }
          },
          "required": ["request", "response"]
        },
        "create_task_branch": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/CreateTaskBranchRequest"
            },
            "response": {
              "$ref": "#/$defs/TaskBranch"
            }
          },
          "required": ["request", "response"]
        },
        "create_task_worktree": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/TaskIdRequest"
            },
            "response": {
              "$ref": "#/$defs/TaskWorktree"
            }
          },
          "required": ["request", "response"]
        },
        "get_task_worktree_status": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/TaskIdRequest"
            },
            "response": {
              "$ref": "#/$defs/WorktreeStatus"
            }
          },
          "required": ["request", "response"]
        },
        "cleanup_task_worktree": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/CleanupTaskWorktreeRequest"
            },
            "response": {
              "$ref": "#/$defs/WorktreeCleanupResult"
            }
          },
          "required": ["request", "response"]
        },
        "execute_task_command": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/ExecuteTaskCommandRequest"
            },
            "response": {
              "$ref": "#/$defs/CommandExecutionResult"
            }
          },
          "required": ["request", "response"]
        },
        "cancel_task_command": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/CancelTaskCommandRequest"
            },
            "response": {
              "$ref": "#/$defs/CommandCancelResult"
            }
          },
          "required": ["request", "response"]
        },
        "read_task_command_log": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/ReadCommandLogRequest"
            },
            "response": {
              "$ref": "#/$defs/CommandLogPage"
            }
          },
          "required": ["request", "response"]
        },
        "summarize_task_command_log": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/CommandLogSummaryRequest"
            },
            "response": {
              "$ref": "#/$defs/CommandLogSummary"
            }
          },
          "required": ["request", "response"]
        },
        "cleanup_expired_task_logs": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/LogCleanupResult"
            }
          },
          "required": ["response"]
        },
        "get_model_config": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/ModelConfigIdRequest"
            },
            "response": {
              "anyOf": [
                {
                  "$ref": "#/$defs/ModelConfigView"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": ["request", "response"]
        },
        "save_model_config": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/SaveModelConfigRequest"
            },
            "response": {
              "$ref": "#/$defs/ModelConfigView"
            }
          },
          "required": ["request", "response"]
        },
        "start_agent_service": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/AgentServiceStatus"
            }
          },
          "required": ["response"]
        },
        "stop_agent_service": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/AgentServiceStatus"
            }
          },
          "required": ["response"]
        },
        "get_agent_service_status": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/AgentServiceStatus"
            }
          },
          "required": ["response"]
        },
        "check_agent_health": {
          "type": "object",
          "properties": {
            "response": {
              "$ref": "#/$defs/AgentHealthResponse"
            }
          },
          "required": ["response"]
        },
        "create_agent_task": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/AgentTaskCreateRequest"
            },
            "response": {
              "$ref": "#/$defs/AgentTaskResponse"
            }
          },
          "required": ["request", "response"]
        },
        "get_agent_task_state": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/TaskIdRequest"
            },
            "response": {
              "$ref": "#/$defs/AgentStateSnapshot"
            }
          },
          "required": ["request", "response"]
        },
        "advance_agent_task": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/AgentTaskAdvanceRequest"
            },
            "response": {
              "$ref": "#/$defs/AgentTaskResponse"
            }
          },
          "required": ["request", "response"]
        },
        "submit_agent_validation_result": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/AgentValidationResultRequest"
            },
            "response": {
              "$ref": "#/$defs/AgentTaskResponse"
            }
          },
          "required": ["request", "response"]
        },
        "run_agent_validation_cycle": {
          "type": "object",
          "properties": {
            "request": {
              "$ref": "#/$defs/RunAgentValidationCycleRequest"
            },
            "response": {
              "$ref": "#/$defs/RunAgentValidationCycleResponse"
            }
          },
          "required": ["request", "response"]
        }
      },
      "required": [
        "health",
        "select_repository_path",
        "validate_repository_path",
        "get_repository_current_branch",
        "get_repository_dirty_status",
        "create_task_branch",
        "create_task_worktree",
        "get_task_worktree_status",
        "cleanup_task_worktree",
        "execute_task_command",
        "cancel_task_command",
        "read_task_command_log",
        "summarize_task_command_log",
        "cleanup_expired_task_logs",
        "get_model_config",
        "save_model_config",
        "start_agent_service",
        "stop_agent_service",
        "get_agent_service_status",
        "check_agent_health",
        "create_agent_task",
        "get_agent_task_state",
        "advance_agent_task",
        "submit_agent_validation_result",
        "run_agent_validation_cycle"
      ]
    }
  },
  "required": ["commands"],
  "$defs": {
    "HealthResponse": {
      "type": "object",
      "properties": {
        "service": {
          "type": "string"
        },
        "status": {
          "const": "ok"
        },
        "version": {
          "type": "string"
        }
      },
      "required": ["service", "status", "version"]
    },
    "AgentHealthResponse": {
      "type": "object",
      "properties": {
        "service": {
          "const": "codemax-agent"
        },
        "status": {
          "const": "ok"
        },
        "version": {
          "type": "string"
        }
      },
      "required": ["service", "status", "version"]
    },
    "AgentServiceStatus": {
      "type": "object",
      "properties": {
        "running": {
          "type": "boolean"
        },
        "pid": {
          "type": ["integer", "null"]
        },
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "healthUrl": {
          "type": "string"
        },
        "agentDir": {
          "type": "string"
        },
        "pythonExecutable": {
          "type": "string"
        },
        "health": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentHealthResponse"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "running",
        "pid",
        "host",
        "port",
        "healthUrl",
        "agentDir",
        "pythonExecutable",
        "health"
      ]
    },
    "RepositoryPathRequest": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "required": ["path"]
    },
    "RepositoryPathSelection": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "required": ["path"]
    },
    "RepositorySummary": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        }
      },
      "required": ["path", "name", "branch", "dirty"]
    },
    "RepositoryBranchInfo": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string"
        }
      },
      "required": ["branch"]
    },
    "RepositoryDirtyStatus": {
      "type": "object",
      "properties": {
        "dirty": {
          "type": "boolean"
        }
      },
      "required": ["dirty"]
    },
    "TaskIdRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        }
      },
      "required": ["taskId"]
    },
    "AgentTaskCreateRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "repositoryPath": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "modelId": {
          "type": ["string", "null"]
        },
        "validationCommand": {
          "type": ["string", "null"]
        }
      },
      "required": ["taskId", "repositoryPath", "worktreePath", "title"]
    },
    "AgentTaskAdvanceRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "reason": {
          "type": ["string", "null"]
        },
        "userMessage": {
          "type": ["string", "null"]
        },
        "requireApproval": {
          "type": "boolean"
        }
      },
      "required": ["taskId"]
    },
    "AgentValidationResultRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": ["string", "null"]
        },
        "command": {
          "type": ["string", "null"]
        },
        "cwd": {
          "type": ["string", "null"]
        },
        "stdout": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "exitCode": {
          "type": ["integer", "null"]
        },
        "timedOut": {
          "type": "boolean"
        },
        "cancelled": {
          "type": "boolean"
        }
      },
      "required": ["taskId"]
    },
    "RunAgentValidationCycleRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "reason": {
          "type": ["string", "null"]
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["taskId"]
    },
    "AgentTaskPhase": {
      "enum": [
        "created",
        "planned",
        "editing",
        "validating",
        "analyzing_error",
        "repairing",
        "waiting_approval",
        "needs_intervention",
        "completed",
        "failed"
      ]
    },
    "AgentValidationRequest": {
      "type": "object",
      "properties": {
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "status": {
          "enum": ["requested", "passed", "failed", "cancelled", "timed_out"]
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["command", "cwd", "reason", "status", "createdAt"]
    },
    "AgentStateSnapshot": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "repositoryPath": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/AgentTaskPhase"
        },
        "validationRequest": {
          "anyOf": [
            {
              "$ref": "#/$defs/AgentValidationRequest"
            },
            {
              "type": "null"
            }
          ]
        },
        "repairRound": {
          "type": "integer",
          "minimum": 0
        },
        "maxRepairRounds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["taskId", "repositoryPath", "worktreePath", "title", "description", "phase"],
      "additionalProperties": true
    },
    "AgentTaskResponse": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "status": {
          "enum": ["created", "accepted"]
        },
        "phase": {
          "$ref": "#/$defs/AgentTaskPhase"
        },
        "checkpointId": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/AgentStateSnapshot"
        }
      },
      "required": ["taskId", "status", "phase", "checkpointId", "state"]
    },
    "RunAgentValidationCycleResponse": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "phase": {
          "$ref": "#/$defs/AgentTaskPhase"
        },
        "iterations": {
          "type": "integer",
          "minimum": 0
        },
        "commandResults": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CommandExecutionResult"
          }
        },
        "state": {
          "$ref": "#/$defs/AgentStateSnapshot"
        }
      },
      "required": ["taskId", "phase", "iterations", "commandResults", "state"]
    },
    "CreateTaskBranchRequest": {
      "type": "object",
      "properties": {
        "repositoryPath": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        }
      },
      "required": ["repositoryPath", "taskId"]
    },
    "CleanupTaskWorktreeRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "confirmed": {
          "type": "boolean"
        }
      },
      "required": ["taskId", "confirmed"]
    },
    "ExecuteTaskCommandRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "timeoutMs": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["taskId", "command", "cwd"]
    },
    "CancelTaskCommandRequest": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        }
      },
      "required": ["runId"]
    },
    "CommandOutputStream": {
      "enum": ["stdout", "stderr"]
    },
    "ReadCommandLogRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "stream": {
          "$ref": "#/$defs/CommandOutputStream"
        },
        "offsetBytes": {
          "type": "integer",
          "minimum": 0
        },
        "maxBytes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["taskId", "runId", "stream"]
    },
    "CommandLogSummaryRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "maxLines": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["taskId", "runId"]
    },
    "TaskBranch": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "branchName": {
          "type": "string"
        }
      },
      "required": ["taskId", "branchName"]
    },
    "TaskWorktree": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "repositoryPath": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "branchName": {
          "type": "string"
        }
      },
      "required": ["taskId", "repositoryPath", "worktreePath", "branchName"]
    },
    "WorktreeFileChange": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "status": {
          "enum": ["added", "modified", "deleted"]
        }
      },
      "required": ["path", "status"]
    },
    "WorktreeStatus": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "branchName": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        },
        "changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/WorktreeFileChange"
          }
        }
      },
      "required": ["taskId", "worktreePath", "branchName", "dirty", "changes"]
    },
    "WorktreeCleanupResult": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "worktreePath": {
          "type": "string"
        },
        "removed": {
          "type": "boolean"
        }
      },
      "required": ["taskId", "worktreePath", "removed"]
    },
    "CommandExecutionResult": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        },
        "status": {
          "enum": ["passed", "failed", "timedOut", "cancelled"]
        },
        "stdoutPath": {
          "type": "string"
        },
        "stderrPath": {
          "type": "string"
        },
        "exitCode": {
          "type": ["integer", "null"]
        },
        "durationMs": {
          "type": "integer",
          "minimum": 0
        },
        "timedOut": {
          "type": "boolean"
        },
        "cancelled": {
          "type": "boolean"
        }
      },
      "required": [
        "runId",
        "taskId",
        "command",
        "cwd",
        "status",
        "stdoutPath",
        "stderrPath",
        "exitCode",
        "durationMs",
        "timedOut",
        "cancelled"
      ]
    },
    "CommandCancelResult": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "cancelled": {
          "type": "boolean"
        }
      },
      "required": ["runId", "cancelled"]
    },
    "CommandLogPage": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "stream": {
          "$ref": "#/$defs/CommandOutputStream"
        },
        "offsetBytes": {
          "type": "integer",
          "minimum": 0
        },
        "nextOffsetBytes": {
          "type": "integer",
          "minimum": 0
        },
        "content": {
          "type": "string"
        },
        "eof": {
          "type": "boolean"
        },
        "compressed": {
          "type": "boolean"
        }
      },
      "required": [
        "taskId",
        "runId",
        "stream",
        "offsetBytes",
        "nextOffsetBytes",
        "content",
        "eof",
        "compressed"
      ]
    },
    "CommandLogSummary": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        },
        "sourceStream": {
          "$ref": "#/$defs/CommandOutputStream"
        },
        "lines": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "truncated": {
          "type": "boolean"
        }
      },
      "required": ["taskId", "runId", "sourceStream", "lines", "truncated"]
    },
    "LogCleanupResult": {
      "type": "object",
      "properties": {
        "retentionDays": {
          "type": "integer"
        },
        "scannedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "deletedFiles": {
          "type": "integer",
          "minimum": 0
        },
        "deletedBytes": {
          "type": "integer",
          "minimum": 0
        },
        "cleanupDisabled": {
          "type": "boolean"
        }
      },
      "required": [
        "retentionDays",
        "scannedFiles",
        "deletedFiles",
        "deletedBytes",
        "cleanupDisabled"
      ]
    },
    "ModelConfigIdRequest": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        }
      },
