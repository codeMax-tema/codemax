{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codemax.local/contracts/agent-api.schema.json",
  "title": "Codemax Agent HTTP API Contract",
  "type": "object",
  "properties": {
    "baseUrl": {
      "const": "http://127.0.0.1:8765"
    },
    "endpoints": {
      "type": "object",
      "properties": {
        "health": {
          "type": "object",
          "properties": {
            "method": {
              "const": "GET"
            },
            "path": {
              "const": "/health"
            },
            "response": {
              "$ref": "#/$defs/HealthResponse"
            }
          },
          "required": ["method", "path", "response"]
        },
        "getModelConfig": {
          "type": "object",
          "properties": {
            "method": {
              "const": "GET"
            },
            "path": {
              "const": "/api/v1/models/config"
            },
            "response": {
              "$ref": "#/$defs/ModelConfigView"
            }
          },
          "required": ["method", "path", "response"]
        },
        "listModelProviders": {
          "type": "object",
          "properties": {
            "method": {
              "const": "GET"
            },
            "path": {
              "const": "/api/v1/models/providers"
            },
            "response": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/ProviderSpec"
              }
            }
          },
          "required": ["method", "path", "response"]
        },
        "createModelChatCompletion": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/models/chat"
            },
            "request": {
              "$ref": "#/$defs/ChatCompletionRequest"
            },
            "response": {
              "$ref": "#/$defs/ChatCompletionResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "addMemoryMessage": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/memory/messages"
            },
            "request": {
              "$ref": "#/$defs/NewConversationMessage"
            },
            "response": {
              "$ref": "#/$defs/ConversationMessage"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "loadMemoryContext": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/memory/context"
            },
            "request": {
              "$ref": "#/$defs/LoadMemoryContextRequest"
            },
            "response": {
              "$ref": "#/$defs/MemoryContextBundle"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "searchMemories": {
          "type": "object",
          "properties": {
            "method": {
              "const": "GET"
            },
            "path": {
              "const": "/api/v1/memory/search"
            },
            "response": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/MemoryItem"
              }
            }
          },
          "required": ["method", "path", "response"]
        },
        "summarizeTempContext": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/memory/temp-context/summary"
            },
            "request": {
              "$ref": "#/$defs/TempContextSummaryRequest"
            },
            "response": {
              "$ref": "#/$defs/TempContextSummary"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "createAgentTask": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/tasks"
            },
            "request": {
              "$ref": "#/$defs/CreateAgentTaskRequest"
            },
            "response": {
              "$ref": "#/$defs/CreateAgentTaskResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "getAgentTaskState": {
          "type": "object",
          "properties": {
            "method": {
              "const": "GET"
            },
            "path": {
              "const": "/api/v1/tasks/{taskId}"
            },
            "response": {
              "$ref": "#/$defs/AgentState"
            }
          },
          "required": ["method", "path", "response"]
        },
        "advanceAgentTask": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/tasks/{taskId}/advance"
            },
            "request": {
              "$ref": "#/$defs/AdvanceAgentTaskRequest"
            },
            "response": {
              "$ref": "#/$defs/AdvanceAgentTaskResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "submitAgentToolResult": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/tasks/{taskId}/tool-result"
            },
            "request": {
              "$ref": "#/$defs/AgentToolResultRequest"
            },
            "response": {
              "$ref": "#/$defs/AdvanceAgentTaskResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "submitAgentValidationResult": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/tasks/{taskId}/validation-result"
            },
            "request": {
              "$ref": "#/$defs/ValidationResultRequest"
            },
            "response": {
              "$ref": "#/$defs/AdvanceAgentTaskResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        },
        "resumeAgentApproval": {
          "type": "object",
          "properties": {
            "method": {
              "const": "POST"
            },
            "path": {
              "const": "/api/v1/tasks/{taskId}/approvals/{approvalId}/resume"
            },
            "request": {
              "$ref": "#/$defs/ResumeApprovalRequest"
            },
            "response": {
              "$ref": "#/$defs/ResumeApprovalResponse"
            }
          },
          "required": ["method", "path", "request", "response"]
        }
      },
      "required": [
        "health",
        "getModelConfig",
        "listModelProviders",
        "createModelChatCompletion",
        "addMemoryMessage",
        "loadMemoryContext",
        "searchMemories",
        "summarizeTempContext",
        "createAgentTask",
        "getAgentTaskState",
        "advanceAgentTask",
        "submitAgentToolResult",
        "submitAgentValidationResult",
        "resumeAgentApproval"
      ]
    }
  },
  "required": ["baseUrl", "endpoints"],
  "$defs": {
    "HealthResponse": {
      "type": "object",
      "properties": {
        "service": {
          "const": "codemax-agent"
        },
        "status": {
          "const": "ok"
        },
        "version": {
          "type": "string"
        }
      },
      "required": ["service", "status", "version"]
    },
    "ModelProvider": {
      "enum": [
        "openai-compatible",
        "claude",
        "deepseek",
        "ds",
        "bailian",
        "volcengine",
        "glm",
        "gemini",
        "openai-gpt",
        "openai-claude",
        "anthropic",
        "relay"
      ]
    },
    "ProviderSpec": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/$defs/ModelProvider"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "enum": ["ready", "placeholder"]
        },
        "implemented": {
          "type": "boolean"
        },
        "defaultBaseUrl": {
          "type": "string"
        },
        "defaultModelName": {
          "type": "string"
        },
        "requiresBaseUrl": {
          "type": "boolean"
        },
        "transport": {
          "enum": ["openai-compatible", "placeholder"]
        },
        "codeLocation": {
          "type": "string"
        },
        "envLocation": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "provider",
        "label",
        "status",
        "implemented",
        "defaultBaseUrl",
        "defaultModelName",
        "requiresBaseUrl",
        "transport",
        "codeLocation",
        "envLocation",
        "note"
      ]
    },
    "ModelConfigView": {
      "type": "object",
      "properties": {
        "provider": {
          "$ref": "#/$defs/ModelProvider"
        },
        "baseUrl": {
          "type": "string"
        },
        "modelName": {
          "type": "string"
        },
        "timeoutSeconds": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "apiKeyConfigured": {
          "type": "boolean"
        },
        "configured": {
          "type": "boolean"
        },
        "status": {
          "enum": ["ready", "placeholder"]
        },
        "implemented": {
          "type": "boolean"
        },
        "codeLocation": {
          "type": "string"
        },
        "envLocation": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "provider",
        "baseUrl",
        "modelName",
        "timeoutSeconds",
        "apiKeyConfigured",
        "configured",
        "status",
        "implemented",
        "codeLocation",
        "envLocation",
        "note"
      ]
    },
    "ChatMessage": {
      "type": "object",
      "properties": {
        "role": {
          "enum": ["system", "user", "assistant"]
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["role", "content"]
    },
    "ChatCompletionRequest": {
      "type": "object",
      "properties": {
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ChatMessage"
          }
        },
        "temperature": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 2
        },
        "maxTokens": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      },
      "required": ["messages"]
    },
    "UsageResponse": {
      "type": "object",
      "properties": {
        "promptTokens": {
          "type": ["integer", "null"]
        },
        "completionTokens": {
          "type": ["integer", "null"]
        },
        "totalTokens": {
          "type": ["integer", "null"]
        }
      },
      "required": ["promptTokens", "completionTokens", "totalTokens"]
    },
    "ChatCompletionResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "finishReason": {
          "type": ["string", "null"]
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/UsageResponse"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": ["id", "model", "content", "finishReason", "usage"]
    },
    "NewConversationMessage": {
      "type": "object",
      "properties": {
        "id": {
          "type": ["string", "null"]
        },
        "conversationId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": ["system", "user", "assistant", "tool"]
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": ["string", "null"]
        },
        "repositoryPath": {
          "type": ["string", "null"]
        },
        "tokenCount": {
          "type": ["integer", "null"]
        },
        "retentionClass": {
          "type": "string"
        }
      },
      "required": ["conversationId", "role", "content"]
    },
    "ConversationMessage": {
      "allOf": [
        {
          "$ref": "#/$defs/NewConversationMessage"
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "createdAt": {
              "type": "string"
            }
          },
          "required": ["id", "createdAt"]
        }
      ]
    },
    "RollingSummary": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "conversationId": {
          "type": "string"
        },
        "coveredMessageCount": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        }
      },
      "required": ["id", "conversationId", "coveredMessageCount", "summary", "updatedAt"]
    },
    "MemoryItem": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "scope": {
          "enum": ["global", "repository", "task"]
        },
        "scopeId": {
          "type": ["string", "null"]
        },
        "key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "category": {
          "enum": [
            "preference",
            "repository_command",
            "solution_choice",
            "approval_decision"
          ]
        },
        "confidence": {
          "type": "number"
        },
        "source": {
          "type": "string"
        },
        "isUserEditable": {
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "scope",
        "scopeId",
        "key",
        "value",
        "category",
        "confidence",
        "source",
        "isUserEditable"
      ],
      "additionalProperties": true
    },
    "LoadMemoryContextRequest": {
      "type": "object",
      "properties": {
        "conversationId": {
          "type": "string",
          "minLength": 1
        },
        "repositoryPath": {
          "type": ["string", "null"]
        },
        "taskId": {
          "type": ["string", "null"]
        },
        "query": {
          "type": ["string", "null"]
        },
        "recentMessageLimit": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 200
        }
      },
      "required": ["conversationId"]
    },
    "MemoryContextBundle": {
      "type": "object",
      "properties": {
        "conversationId": {
          "type": "string"
        },
        "recentMessageLimit": {
          "type": "integer"
        },
        "recentMessages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ConversationMessage"
          }
        },
        "rollingSummary": {
          "anyOf": [
            {
              "$ref": "#/$defs/RollingSummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "longTermMemories": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryItem"
          }
        },
        "safetyNotice": {
          "type": "string"
        }
      },
      "required": [
        "conversationId",
        "recentMessageLimit",
        "recentMessages",
        "rollingSummary",
        "longTermMemories",
        "safetyNotice"
      ]
    },
    "TempContextSummaryRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["taskId", "items"]
    },
    "TempContextSummary": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "taskId": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "sourceItemCount": {
          "type": "integer",
          "minimum": 0
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "taskId", "summary", "sourceItemCount", "createdAt"]
    },
    "AgentTaskPhase": {
      "enum": [
        "created",
        "planned",
        "editing",
        "validating",
        "analyzing_error",
        "repairing",
        "waiting_approval",
        "needs_intervention",
        "completed",
        "failed"
      ]
    },
    "CreateAgentTaskRequest": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "repositoryPath": {
          "type": "string",
          "minLength": 1
        },
        "worktreePath": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "modelId": {
          "type": ["string", "null"]
        },
        "validationCommand": {
          "type": ["string", "null"]
        }
      },
      "required": ["taskId", "repositoryPath", "worktreePath", "title"]
    },
    "CreateAgentTaskResponse": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "status": {
          "const": "created"
        },
        "phase": {
          "$ref": "#/$defs/AgentTaskPhase"
        },
        "message": {
          "type": "string"
        },
        "checkpointId": {
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/AgentState"
        }
      },
      "required": ["taskId", "status", "phase", "checkpointId", "message", "state"]
    },
    "AdvanceAgentTaskRequest": {
      "type": "object",
      "properties": {
        "reason": {
          "type": ["string", "null"]
        },
        "userMessage": {
          "type": ["string", "null"]
        },
        "requireApproval": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "AdvanceAgentTaskResponse": {
      "type": "object",
      "properties": {
        "taskId": {
          "type": "string"
        },
        "status": {
          "const": "accepted"
        },
        "phase": {
          "$ref": "#/$defs/AgentTaskPhase"
        },
        "checkpointId": {
          "type": "string"
        },
        "state": {
          "$ref": "#/$defs/AgentState"
        }
      },
      "required": ["taskId", "status", "phase", "checkpointId", "state"],
      "additionalProperties": false
    },
    "AgentToolResultRequest": {
      "type": "object",
      "properties": {
        "callId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "\\S"
        },
        "toolName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "\\S"
        },
        "status": {
          "enum": ["succeeded", "failed", "rejected", "cancelled", "waiting_approval"]
        },
        "output": {
          "type": "object",
          "default": {},
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          }
        },
        "errorCode": {
          "type": ["string", "null"],
          "maxLength": 256
        },
        "errorMessage": {
          "type": ["string", "null"],
          "maxLength": 16000
        },
        "artifactRefs": {
          "type": "array",
          "default": [],
          "maxItems": 16,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          }
        },
        "truncated": {
          "type": "boolean",
          "default": false
        }
      },
      "required": ["callId", "toolName", "status"],
      "additionalProperties": false
    },
    "JsonValueDepth2": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth3"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth3"
          }
        }
      ]
    },
    "JsonValueDepth3": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth4"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth4"
          }
        }
      ]
    },
    "JsonValueDepth4": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth5"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth5"
          }
        }
      ]
    },
    "JsonValueDepth5": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth6"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth6"
          }
        }
      ]
    },
    "JsonValueDepth6": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth7"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth7"
          }
        }
      ]
    },
    "JsonValueDepth7": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth8"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth8"
          }
        }
      ]
    },
    "JsonValueDepth8": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth9"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth9"
          }
        }
      ]
    },
    "JsonValueDepth9": {
      "anyOf": [
        {
          "type": ["string", "number", "integer", "boolean", "null"]
        },
        {
          "type": "array",
          "maxItems": 256,
          "items": {
            "$ref": "#/$defs/JsonValueDepth10"
          }
        },
        {
          "type": "object",
          "maxProperties": 256,
          "additionalProperties": {
            "$ref": "#/$defs/JsonValueDepth10"
          }
        }
      ]
    },
