# Storage locations are optional. Empty values mean the app will use the OS app-data directory.
CODEMAX_APP_DATA_DIR=
CODEMAX_WORKTREE_ROOT=
CODEMAX_ARTIFACT_ROOT=
CODEMAX_DATABASE_URL=sqlite://app-data/app.db

# Retention and resource controls
CODEMAX_KEEP_RECENT_MESSAGES=50
CODEMAX_RAW_LOG_RETENTION_DAYS=30
CODEMAX_SCREENSHOT_RETENTION_DAYS=30
CODEMAX_TEMP_CONTEXT_RETENTION_DAYS=7
CODEMAX_MAX_REPAIR_ROUNDS=5

# UI and localization
CODEMAX_DEFAULT_LOCALE=zh-CN
CODEMAX_FALLBACK_LOCALE=en-US
CODEMAX_DEFAULT_THEME=minimal

# Model provider. Do not commit real API keys.
CODEMAX_MODEL_PROVIDER=openai-compatible
CODEMAX_MODEL_BASE_URL=
CODEMAX_MODEL_NAME=
CODEMAX_MODEL_API_KEY=

