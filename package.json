{
  "name": "codemax-agent-task-console",
  "version": "0.0.0",
  "private": true,
  "description": "Local desktop command center for AI coding agent tasks.",
  "type": "module",
  "packageManager": "npm@10.9.3",
  "scripts": {
    "check": "npm run check:architecture && npm run check:frontend",
    "check:architecture": "node tests/architecture/verify-architecture.mjs",
    "check:frontend": "node tests/frontend/verify-s6-ui.mjs",
    "check:a-line": "node scripts/check-a-line.mjs",
    "check:s11": "node scripts/check-s11.mjs",
    "check:tauri": "cargo check --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "build:desktop": "npm --workspace @codemax/desktop run build",
    "build:tauri:debug": "npm --workspace @codemax/desktop run tauri -- build --debug --no-bundle",
    "dev:desktop": "npm --workspace @codemax/desktop run dev -- --host 127.0.0.1"
  },
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "monaco-editor": "0.53.0"
  },
  "overrides": {
    "monaco-editor": "0.53.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
